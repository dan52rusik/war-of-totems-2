sysinfo.txt
*.stacktrace

# OS cruft
.DS_Store
Thumbs.db
Desktop.ini

# Test and coverage output
TestResults/
coverage/

# Build artifacts
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.dll
*.zip

# Keep important Unity text assets tracked
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**
!/[Pp]roject[Ss]ettings/**
